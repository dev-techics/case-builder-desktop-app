{
  "name": "case-builder-desktop",
  "version": "0.1.0",
  "author": {
    "name": "Anik Dey",
    "email": "contact@anikdey.com"
  },
  "description": "Case Builder desktop application",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "build:renderer": "npm --prefix frontend run build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build:electron && electron .",
    "dev:renderer": "npm --prefix frontend run dev",
    "dev:electron": "wait-on tcp:3000 && npm run build:electron && electron . --ozone-platform=x11",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:linux": "npm run build && electron-builder --linux deb",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.2",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "pdf-lib": "^1.17.1",
    "uuid": "^13.0.0",
    "@case-builder/ui": "github:dev-techics/case-builder-ui"
  }
}
