{
    "build": {
    "appId": "com.casebuilder.desktop",
    "productName": "CaseBuilder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-react/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility"
    }
  }
}